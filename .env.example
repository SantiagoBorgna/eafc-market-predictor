# ==========================================
# Archivo de Configuración de CardsBot
# Renombrar este archivo a ".env" antes de usar
# ==========================================

# 🤖 TELEGRAM BOT
# Reemplazar con el token entregado por BotFather
TELEGRAM_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxyz

# 👑 IDENTIDAD Y SOPORTE
# Tu Telegram ID numérico para recibir alertas críticas e instalarte como Dios del Bot
ADMIN_ID=123456789

# Usuario de contacto que verá la gente (ej: @TuUsuario)
SUPPORT_CONTACT=@TuUsuarioSoporte

# Grupo VIP (opcional). El bot pateara a los vencidos de este grupo automáticamente
VIP_GROUP_ID=-100123456789
VIP_GROUP_LINK=https://t.me/+AbCdEfGhIjKl

# 💰 PAGOS (Opcional, dejar vacio si no se usa alguno)
MP_SUBSCRIPTION_LINK=https://www.mercadopago.com.ar/subscriptions/checkout?preapproval_plan_id=abcd...
PAYMENT_ALIAS=tu.alias.mp
BINANCE_ADDRESS=0xTuDireccionWallet123 (Red BEP20)
PAYPAL_LINK=https://paypal.me/TuCuenta
